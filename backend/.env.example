APP_NAME=Scoutly API
FRONTEND_ORIGIN=http://localhost:3000

# eBay Browse API credentials
EBAY_CLIENT_ID=replace_with_ebay_app_id_or_client_id
EBAY_CLIENT_SECRET=replace_with_ebay_cert_id_or_client_secret
EBAY_MARKETPLACE_ID=EBAY_US
EBAY_ENV=production
EBAY_DELIVERY_COUNTRY=US
# Optional, helps eBay calculate total price when sorting by price.
# EBAY_DELIVERY_POSTAL_CODE=90210

# Optional eBay Partner Network tracking. Add these after ePN approval.
# EBAY_AFFILIATE_CAMPAIGN_ID=1234567890
# EBAY_AFFILIATE_REFERENCE_ID=scoutly

# eBay Marketplace Account Deletion notification setup
EBAY_NOTIFICATION_ENDPOINT_URL=https://scoutly-production-f472.up.railway.app/api/ebay/notifications
EBAY_NOTIFICATION_VERIFICATION_TOKEN=replace_with_32_to_80_chars_letters_numbers_underscores_or_hyphens

# Persistent PostgreSQL storage. Railway can set this as a reference variable:
# DATABASE_URL=${{Postgres.DATABASE_URL}}
# Local development may omit DATABASE_URL to use temporary JSON-file storage.

# Required for /api/analytics/* and /admin. Keep this private.
SCOUTLY_ADMIN_TOKEN=replace_with_private_admin_token

# KEH Camera / Awin feed integration. Keep the feed URL private in Railway.
AWIN_KEH_FEED_URL=https://productdata.awin.com/datafeed/download/...
KEH_FEED_ENABLED=false
# Enables public camera and lens results derived from the KEH feed.
KEH_PUBLIC_RESULTS=false
# Catalog-matched cameras can use eBay + KEH. Additional camera models are
# grouped by KEH's standardized title and stay KEH-only.
